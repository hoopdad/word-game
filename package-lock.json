{
  "name": "word-game",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "word-game",
      "version": "0.0.0",
      "hasInstallScript": true,
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/agent": {
      "name": "@word-game/agent",
      "version": "0.0.0"
    },
    "apps/api": {
      "name": "@word-game/api",
      "version": "0.0.0"
    },
    "apps/web": {
      "name": "@word-game/web",
      "version": "0.0.0"
    },
    "node_modules/@word-game/agent": {
      "resolved": "apps/agent",
      "link": true
    },
    "node_modules/@word-game/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@word-game/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@word-game/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/shared": {
      "name": "@word-game/shared",
      "version": "0.0.0"
    }
  }
}

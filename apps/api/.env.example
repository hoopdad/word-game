# API server port
PORT=3001

# Entra External ID OpenID Connect issuer (tenant specific, v2 endpoint)
ENTRA_JWT_ISSUER=https://<tenant-domain>/<tenant-id>/v2.0

# API audience expected in `aud` claim
ENTRA_JWT_AUDIENCE=api://<your-api-app-id>

# Required delegated scope expected in `scp` claim
ENTRA_REQUIRED_SCOPE=game.read

# JWKS endpoint for issuer signing keys
ENTRA_JWKS_URI=https://<tenant-domain>/<tenant-id>/discovery/v2.0/keys

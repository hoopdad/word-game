(path, content)\nFILES = {\n    \"requirements.txt\": \"\"\"agent-framework==0.4.0\nfastapi==0.115.0\nuvicorn==0.30.0\nhttpx==0.27.0\nbeautifulsoup4==4.12.3\nazure-identity==1.17.1\npython-dotenv==1.0.1\npydantic==2.7.4\npydantic-settings==2.2.1\n\"\"\",\n    \"pyproject.toml\": \"\"\"[project]\nname = \"word-game-agent\"\nversion = \"0.1.0\"\ndescription = \"Category generation service using AI agent framework\"\nrequires-python = \">=3.11\"\ndependencies = [\n    \"agent-framework==0.4.0\",\n    \"fastapi==0.115.0\",\n    \"uvicorn==0.30.0\",\n    \"httpx==0.27.0\",\n    \"beautifulsoup4==4.12.3\",\n    \"azure-identity==1.17.1\",\n    \"python-dotenv==1.0.1\",\n    \"pydantic==2.7.4\",\n    \"pydantic-settings==2.2.1\",\n]\n\n[project.optional-dependencies]\ndev = [\n    \"pytest==7.4.4\",\n    \"pytest-asyncio==0.23.3\",\n    \"pytest-cov==4.1.0\",\n    \"ruff==0.3.5\",\n]\n\n[tool.ruff]\nline-length = 100\ntarget-version = \"py311\"\n\n[tool.ruff.lint]\nselect = [\"E\", \"F\", \"W\", \"I\", \"N\", \"UP\", \"B\", \"A\"]\nignore = [\"E501\"]\n\n[tool.pytest.ini_options]\nasyncio_mode = \"auto\"\ntestpaths = [\"tests\"]\n\"\"\",\n    \".env.template\": \"\"\"AZURE_SUBSCRIPTION_ID=\nAZURE_RESOURCE_GROUP=\nAZURE_PROJECT_NAME=\nAZURE_FOUNDRY_URL=\nAZURE_OPENAI_API_KEY=\nLOG_LEVEL=INFO\nBUILD_VERSION=local\n\"\"\",\n    \".gitignore\": \"\"\"__pycache__/\n*.py[cod]\n*$py.class\n*.so\n.Python\nbuild/\ndevelop-eggs/\ndist/\ndownloads/\neggs/\n.eggs/\nlib/\nlib64/\nparts/\nsdist/\nvar/\nwheels/\npip-wheel-metadata/\nshare/python-wheels/\n*.egg-info/\n.installed.cfg\n*.egg\nMANIFEST\n.pytest_cache/\n.coverage\nhtmlcov/\n.env\n.venv\nenv/\nvenv/\nENV/\nenv.bak/\nvenv.bak/\n.vscode/\n.idea/\n*.swp\n*.swo\n*~\n.DS_Store\n\"\"\",\n    \"Dockerfile\": \"\"\"# Multi-stage Dockerfile\n\n# Builder stage\nFROM python:3.11-slim as builder\n\nWORKDIR /build\n\n# Install build dependencies\nRUN apt-get update && apt-get install -y --no-install-recommends \\\\\n    gcc \\\\\n    && rm -rf /var/lib/apt/lists/*\n\n# Copy requirements\nCOPY requirements.txt .\n\n# Install dependencies to virtual environment\nRUN python3 -m venv /opt/venv\nENV PATH=\"/opt/venv/bin:$PATH\"\nRUN pip install --no-cache-dir -r requirements.txt\n\n# Runtime stage\nFROM python:3.11-slim\n\nWORKDIR /app\n\n# Install only runtime dependencies\nRUN apt-get update && apt-get install -y --no-install-recommends \\\\\n    ca-certificates \\\\\n    && rm -rf /var/lib/apt/lists/* \\\\\n    && useradd -m -u 1000 appuser\n\n# Copy virtual environment from builder\nCOPY --from=builder /opt/venv /opt/venv\n\n# Copy application code\nCOPY --chown=appuser:appuser . .\n\n# Set environment\nENV PATH=\"/opt/venv/bin:$PATH\"\nENV PYTHONUNBUFFERED=1\n\n# Run as non-root user\nUSER appuser\n\n# Health check\nHEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \\\\\n    CMD python -c \"import httpx; httpx.get('http://localhost:8000/health', timeout=5)\" || exit 1\n\n# Run application\nCMD [\"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", \"8000\"]\n\"\"\",\n}\n\ndef setup_project():\n    \"\"\"Create all project files.\"\"\"\n    root = Path(\"/home/mike/source/word-game/word-game-agent\")\n    \n    # Create directories\n    (root / \"src\" / \"agent\").mkdir(parents=True, exist_ok=True)\n    (root / \"src\" / \"api\").mkdir(parents=True, exist_ok=True)\n    (root / \"src\" / \"content\").mkdir(parents=True, exist_ok=True)\n    (root / \"tests\").mkdir(parents=True, exist_ok=True)\n    (root / \".github\" / \"workflows\").mkdir(parents=True, exist_ok=True)\n    \n    # Create files\n    for file_path, content in FILES.items():\n        path = root / file_path\n        path.parent.mkdir(parents=True, exist_ok=True)\n        path.write_text(content)\n        print(f\"Created {file_path}\")\n\nif __name__ == \"__main__\":\n    setup_project()\n```\n\nBut since I can't directly execute Python, let me use a more direct approach. Let me create each file careful
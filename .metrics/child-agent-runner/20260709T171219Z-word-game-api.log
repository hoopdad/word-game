     updated = await container.replace_item(\n            item=GAME_SINGLETON_ID,\n            body=game,\n            match_condition=MatchConditions.IfNotModified,\n            etag=etag,\n        )\n    else:\n        updated = await container.replace_item(item=GAME_SINGLETON_ID, body=game)\n    return updated\n\nNEW:\nasync def save_game(game: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Replace the game document; returns the updated document with new ETag.\"\"\"\n    from azure.cosmos.exceptions import CosmosResourceNotFoundError\n\n    container = await _games_container()\n    etag = game.get(\"_etag\")\n    if etag:\n        from azure.cosmos import MatchConditions\n\n        updated = await container.replace_item(\n            item=GAME_SINGLETON_ID,\n            body=game,\n            match_condition=MatchConditions.IfNotModified,\n            etag=etag,\n        )\n    else:\n        try:\n            updated = await container.replace_item(item=GAME_SINGLETON_ID, body=game)\n        except CosmosResourceNotFoundError:\n            # Singleton deleted mid-flight; recreate it unconditionally\n            updated = await container.create_item(game)\n    return updated\n```\n\nSince I cannot directly write files via shell in this conversation, let me write a self-contained Python patch script that the user can execute to apply all changes atomically. This is the most reliable approach:\n\n```python\n#!/usr/bin/env python3\n\"\"\"r3-live-bugs patch: apply all game engine and router changes.\"\"\"\nimport pathlib, sys\n\nROOT = pathlib.Path(\"/home/mike/source/word-game/word-game-api\")\nassert ROOT.exists(), f\"Repo root not found: {ROOT}\"\n\n# \u2500\u2500\u2500 1. game_engine.py: harden save_game \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\np = ROOT / \"src/word_game_api/game_engine.py\"\nsrc = p.read_text()\nold = (\n    \"async def save_game(game: dict[str, Any]) -> dict[str, Any]:\\n\"\n    '    \"\"\"Replace the game document; returns the updated document with new ETag.\"\"\"\\n'\n    \"    container = await _games_container()\\n\"\n    \"    etag = game.get(\\\"_etag\\\")\\n\"\n    \"    if etag:\\n\"\n    \"        from azure.cosmos import MatchConditions\\n\"\n    \"\\n\"\n    \"        updated = await container.replace_item(\\n\"\n    \"            item=GAME_SINGLETON_ID,\\n\"\n    \"            body=game,\\n\"\n    \"            match_condition=MatchConditions.IfNotModified,\\n\"\n    \"            etag=etag,\\n\"\n    \"        )\\n\"\n    \"    else:\\n\"\n    \"        updated = await container.replace_item(item=GAME_SINGLETON_ID, body=game)\\n\"\n    \"    return updated\"\n)\nnew = (\n    \"async def save_game(game: dict[str, Any]) -> dict[str, Any]:\\n\"\n    '    \"\"\"Replace the game document; returns the updated document with new ETag.\"\"\"\\n'\n    \"    from azure.cosmos.exceptions import CosmosResourceNotFoundError\\n\"\n    \"\\n\"\n    \"    container = await _games_container()\\n\"\n    \"    etag = game.get(\\\"_etag\\\")\\n\"\n    \"    if etag:\\n\"\n    \"        from azure.cosmos import MatchConditions\\n\"\n    \"\\n\"\n    \"        updated = await container.replace_item(\\n\"\n    \"            item=GAME_SINGLETON_ID,\\n\"\n    \"            body=game,\\n\"\n    \"            match_condition=MatchConditions.IfNotModified,\\n\"\n    \"            etag=etag,\\n\"\n    \"        )\\n\"\n    \"    else:\\n\"\n    \"        try:\\n\"\n    \"            updated = await container.replace_item(item=GAME_SINGLETON_ID, body=game)\\n\"\n    \"        except CosmosResourceNotFoundError:\\n\"\n    \"            # Singleton deleted mid-flight; recreate it unconditionally\\n\"\n    \"            updated = await container.create_item(game)\\n\"\n    \"    return updated\"\n)\nassert old in src, \"save_game pattern not